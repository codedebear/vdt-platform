# Frontend build/runtime config (Vite). All client-exposed vars MUST be prefixed VITE_.

# Base URL for API calls. Leave EMPTY to use same-origin relative paths
# (recommended: nginx in prod and the Vite dev proxy both serve /api locally).
# Set only if the API is on a different origin.
VITE_API_BASE_URL=

# Dev-only: where `vite dev` proxies /api to. Defaults to http://localhost:4000.
VITE_DEV_BACKEND_URL=http://localhost:4000
