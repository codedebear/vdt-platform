{
  "name": "vdt-qa-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "VDT Platform QA execution worker (QAX-3C) — runs compiled HTTP test artifacts against a non-prod target.",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "node --import tsx --test src/core.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^20.16.5"
  }
}
