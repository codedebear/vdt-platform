# VDT QA worker configuration (QAX-3C). Copy to .env and fill in.

# Backend base URL (the Pi). e.g. http://192.168.1.13:4000
VDT_API_URL=http://localhost:4000
# Must match the backend's WORKER_TOKEN.
WORKER_TOKEN=
# A label identifying this worker (shows as the lease holder). Defaults to worker-<pid>.
WORKER_ID=laptop-1

# Optional tuning.
WORKER_POLL_MS=5000          # how often to poll for a job when idle
WORKER_LEASE_MS=120000       # must match the backend lease; heartbeat is half this
WORKER_HTTP_TIMEOUT_MS=30000 # per-request timeout against the target (HTTP steps)
WORKER_BROWSER_TIMEOUT_MS=30000 # per-action/assertion timeout for browser steps (Playwright)
WORKER_MAX_EVIDENCE_BYTES=1500000
