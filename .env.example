# Database — Neon (managed serverless Postgres). Get this from the Neon console,
# under your project's "Connection string" (use the pooled connection if you expect
# many short-lived connections; direct connection is fine for this single backend process).
# sslmode=require is mandatory — Neon rejects unencrypted connections.
DATABASE_URL=postgresql://<user>:<password>@<your-project>.neon.tech/<dbname>?sslmode=require

# Backend
JWT_SECRET=changeme-super-secret-min-16-chars
JWT_EXPIRES_IN=8h
PORT=4000
NODE_ENV=production

# AI generation (Anthropic). Required only to use the /generate endpoints.
# Without ANTHROPIC_API_KEY the app still boots; generate calls return 503.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8000
ANTHROPIC_TIMEOUT_MS=120000
ANTHROPIC_MAX_RETRIES=2

# Cost / abuse guards for the /generate endpoint
GENERATE_RATE_LIMIT_PER_MIN=10
GENERATE_MAX_PER_RUN=5

# Per-project AI cost budget (approximate USD). Applied to new projects;
# 0 = unlimited. Enforced as a hard block on /generate once a project's
# accumulated spend reaches it.
PROJECT_BUDGET_USD_DEFAULT=0
# Optional per-million-token price overrides for the active model (0 = use the
# built-in pricing table). Set if Anthropic prices change, to keep estimates accurate.
ANTHROPIC_PRICE_INPUT_PER_MTOK=0
ANTHROPIC_PRICE_OUTPUT_PER_MTOK=0
# Prompt cost guards: cap stored run input and each prior-phase output folded
# into a generation prompt.
INPUT_MAX_CHARS=100000
PRIOR_OUTPUT_MAX_CHARS=20000

# Anthropic Message Batches API (async generation at ~50% cost). BATCH_ENABLED
# gates both the per-generate batch mode and the background poller. The poller
# scans QUEUED runs every BATCH_POLL_INTERVAL_MS. ANTHROPIC_BATCH_PRICE_FACTOR is
# the fraction of standard price charged for batch runs (Anthropic bills 50%).
BATCH_ENABLED=true
BATCH_POLL_INTERVAL_MS=30000
ANTHROPIC_BATCH_PRICE_FACTOR=0.5
# Safety cutoffs so a run never sticks in QUEUED: fail (and release budget) a run
# older than BATCH_MAX_AGE_MS (default 26h, past the 24h batch SLA) or one still
# missing its batchId after BATCH_SUBMIT_GRACE_MS (default 5 min = crashed submit).
BATCH_MAX_AGE_MS=93600000
BATCH_SUBMIT_GRACE_MS=300000

# Secrets vault master key (QAX-3A): 32 bytes as 64 hex chars or base64, used to
# AES-256-GCM encrypt project QA secrets at rest. Generate with: openssl rand -hex 32
# Optional (app boots without it; setting/using a secret then returns 503).
SECRETS_KEY=

# Frontend (nginx container). Host port the SPA is published on.
FRONTEND_PORT=8080
# Leave empty for same-origin API (nginx proxies /api to the backend).
# Set only if the API is served from a different origin.
VITE_API_BASE_URL=
