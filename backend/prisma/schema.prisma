generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A user account that can sign in to the VDT Platform.
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(OPERATION)
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/// Global authorization role assigned to a user. Determines which workflow
/// actions the user may perform across all projects (role is not scoped per
/// project in this phase). SUPER_ADMIN may do everything; PROJECT_OWNER creates
/// projects and reviews/approves phases on projects they own; BA/SA/QA/OPERATION
/// are the "worker" roles that run specific phase types. The single source of
/// truth for what each role may do is domain/permissions.ts.
enum Role {
  SUPER_ADMIN
  PROJECT_OWNER
  BA
  SA
  QA
  OPERATION
}

/// A software project managed by the platform. Its `track` decides which
/// phases apply: FULL_SDLC runs the full Planner→Dev→QA→Review→Docs flow,
/// while QA_ONLY runs a lightweight Planner (test scope) followed by
/// repeatable QA cycles for clients who already have code.
model Project {
  id          String           @id @default(uuid())
  name        String
  description String?
  track       Track            @default(FULL_SDLC)
  status      ProjectStatus    @default(ACTIVE)
  owner       User             @relation(fields: [ownerId], references: [id])
  ownerId     String
  executions  PhaseExecution[]
  // Per-project AI cost budget (approximate USD). `budgetUsd` is the lifetime
  // cap (null = unlimited); `spentUsd` accumulates the estimated cost of every
  // AI generation on the project and is enforced as a hard block.
  budgetUsd   Float?
  spentUsd    Float            @default(0)
  // QA execution config (QAX-3A): the non-prod target the compiled tests run
  // against, and the encrypted secrets that resolve ${VAR} placeholders.
  target      TargetEnvironment?
  secrets     Secret[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

/// The non-production environment a project's compiled QA tests execute against
/// (QAX-3A). One per project. `hostAllowlist` is the set of hosts the execution
/// worker is permitted to hit (anything else is refused); `isNonProd` must stay
/// true in v1 (prod execution is deferred).
model TargetEnvironment {
  id            String   @id @default(uuid())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String   @unique
  label         String?
  baseUrl       String
  hostAllowlist String[]
  isNonProd     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// A project-scoped secret (test credential / token) used to resolve a `${name}`
/// placeholder in a compiled artifact at execute time (QAX-3A). The value is
/// stored AES-256-GCM encrypted (ciphertext + iv + authTag, base64); the
/// plaintext is never persisted, returned by the API, or logged.
model Secret {
  id         String   @id @default(uuid())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  name       String
  ciphertext String
  iv         String
  authTag    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

/// One run of a single phase for a project. A phase type may have many runs
/// (e.g. repeatable QA cycles, or a re-run after CHANGES_REQUESTED), so history
/// is preserved as separate rows rather than overwritten. `runNumber` is a
/// 1-based counter scoped to (project, phaseType).
model PhaseExecution {
  id          String      @id @default(uuid())
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  phaseType   PhaseType
  runNumber   Int
  status      PhaseStatus @default(IN_PROGRESS)
  input       String?
  output      String?
  reviewNote  String?
  // AI generation accounting (sub-phase 3.5). Nullable token counts from the
  // last generation; generationCount caps repeated regenerations per run.
  inputTokens     Int?
  outputTokens    Int?
  // Estimated USD cost of the most recent AI generation on this run. While a
  // batch run is QUEUED this transiently holds the *reserved* (upper-bound) cost
  // until the poller settles it to the actual cost on completion (BE-BATCH-1).
  costUsd         Float?
  generationCount Int      @default(0)
  // Anthropic Message Batch id for a run generated asynchronously via the Batch
  // API (BE-BATCH-1). Null for synchronous runs. The background poller uses it
  // to retrieve results and move a QUEUED run to AWAITING_REVIEW or FAILED.
  batchId         String?
  attachments Attachment[]
  // The staged QA-execution run attached to a QA phase (QAX-1). At most one per
  // PhaseExecution; only QA-type runs have one. Cascade-deleted with the phase.
  testRun     TestRun?
  startedAt   DateTime    @default(now())
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([projectId, phaseType, runNumber])
  @@index([projectId, phaseType])
}

/// One staged QA-execution run (QAX-1), 1:1 with a QA `PhaseExecution`. Holds the
/// QA stage state machine plus the UATR document metadata, and is the root of the
/// TestScenario → TestStep → TestResult tree that the UATR Excel export is built
/// from. The QA flow's stage rules live in domain/qaExecution.ts.
model TestRun {
  id            String          @id @default(uuid())
  execution     PhaseExecution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionId   String          @unique
  stage         QaStage         @default(SCENARIO_DRAFT)
  // UATR "Amendment" (document history) metadata.
  version       String          @default("1.0")
  preparedBy    String?
  reviewedBy    String?
  approvedBy    String?
  // Rolled-up overall result for the UATR summary (computed from step results).
  overallResult ScenarioResult?
  startedAt     DateTime?
  finishedAt    DateTime?
  // Execution-worker lease (QAX-3B). While a run is EXECUTING a worker claims it
  // by setting claimedBy + a leaseExpiresAt in the future; the claim is released
  // (or expires) so another worker can pick up an abandoned run.
  claimedAt      DateTime?
  claimedBy      String?
  leaseExpiresAt DateTime?
  // Per-run plaintext test data injected at COMPILED stage (e.g. IMEI, SO numbers).
  // Merged with project secrets at worker claim time; run-specific values override.
  params        Json?
  scenarios     TestScenario[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([executionId])
  @@index([stage])
}

/// A single test case within a run — one block in the UATR "Detail Test Scenario
/// Summary" sheet. `no` is the 1-based ordinal shown in the sheet's No. column.
model TestScenario {
  id        String          @id @default(uuid())
  run       TestRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId     String
  no        Int
  topic     String
  testName  String
  system    String?
  remark    String?
  // Rolled-up result for this scenario (UATR summary), computed from its steps.
  result    ScenarioResult?
  steps     TestStep[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([runId, no])
  @@index([runId])
}

/// One ordered step of a scenario (a row in the UATR detail sheet). Once the run
/// reaches COMPILED, `artifactType`/`artifactSpec` hold the replayable executable
/// (HTTP request spec or Playwright actions + assertion) the worker runs — built
/// once by the AI, then re-run at zero token cost.
model TestStep {
  id             String            @id @default(uuid())
  scenario       TestScenario      @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId     String
  order          Int
  stepName       String
  expectedResult String
  artifactType   TestArtifactType?
  artifactSpec   Json?
  result         TestResult?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([scenarioId, order])
  @@index([scenarioId])
}

/// The recorded outcome of executing one step in this run, 1:1 with a TestStep.
/// `evidence` optionally stores a screenshot or response body inline (bytea) —
/// keep it small; Neon's free tier is only 0.5GB, so a later sub-phase may move
/// evidence to object storage behind the same interface.
model TestResult {
  id           String     @id @default(uuid())
  step         TestStep   @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId       String     @unique
  status       TestStatus @default(NOT_START)
  actualResult String?
  evidence     Bytes?
  evidenceMime String?
  durationMs   Int?
  executedAt   DateTime?
  remark       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

/// A document attached to a phase run, supplied as extra context the AI reads
/// when generating that phase's output (e.g. an SRS or API spec). Stored inline
/// as bytea — see the attachments design note. Deleted with its run (cascade).
model Attachment {
  id          String         @id @default(uuid())
  execution   PhaseExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionId String
  filename    String
  mimeType    String
  sizeBytes   Int
  data        Bytes
  createdAt   DateTime       @default(now())

  @@index([executionId])
}

/// The workflow track a project follows.
enum Track {
  FULL_SDLC
  QA_ONLY
}

/// High-level lifecycle status of a project.
enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

/// The kind of work a phase execution represents.
enum PhaseType {
  PLANNER
  DEV
  QA
  CODE_REVIEW
  DOCS
}

/// Lifecycle status of a single phase execution (one run).
/// QUEUED means the run's output is being generated asynchronously via the
/// Anthropic Batch API; the background poller advances it to AWAITING_REVIEW on
/// success or FAILED on error/expiry (BE-BATCH-1).
enum PhaseStatus {
  IN_PROGRESS
  QUEUED
  AWAITING_REVIEW
  APPROVED
  CHANGES_REQUESTED
  FAILED
}

/// Stages a staged QA-execution run (TestRun) moves through (QAX-1). The ordered
/// transitions and roll-up rules live in domain/qaExecution.ts.
enum QaStage {
  SCENARIO_DRAFT
  STEPS_DRAFT
  COMPILED
  EXECUTING
  RESULTS_REVIEW
  EXPORTED
}

/// Per-step execution status — the UATR detail sheet's "Status" column.
/// SKIPPED marks a step the worker could not run yet (e.g. a BROWSER step before
/// the Playwright worker exists); terminal but counts as "not verified".
enum TestStatus {
  NOT_START
  IN_PROGRESS
  PASS
  FAIL
  SKIPPED
}

/// Rolled-up result for a scenario or whole run — the UATR summary legend.
enum ScenarioResult {
  PASS
  FAIL
  IN_PROGRESS
  NOT_COMPLETE
  NO_RUN
}

/// What kind of executable a compiled step produces.
enum TestArtifactType {
  HTTP
  BROWSER
}
