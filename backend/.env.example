# Local dev: point this at your own Neon connection string (or a Neon "dev" branch
# if you want to keep local work isolated from the shared/prod branch).
DATABASE_URL=postgresql://<user>:<password>@<your-project>.neon.tech/<dbname>?sslmode=require
JWT_SECRET=changeme-super-secret-min-16-chars
JWT_EXPIRES_IN=8h
PORT=4000
NODE_ENV=development

# Attachment limits (optional — these defaults apply if unset). Files are stored
# inline in Postgres, so keep these tight on Neon's free tier.
ATTACHMENT_MAX_FILE_MB=10
ATTACHMENT_MAX_PER_RUN=5
ATTACHMENT_MAX_TOTAL_MB=25
ATTACHMENT_RATE_LIMIT_PER_MIN=20
ATTACHMENT_TEXT_CHAR_CAP=100000

# Per-project AI cost budget (approximate USD; 0 = unlimited) + optional price
# overrides per million tokens (0 = use the built-in pricing table).
PROJECT_BUDGET_USD_DEFAULT=0
ANTHROPIC_PRICE_INPUT_PER_MTOK=0
ANTHROPIC_PRICE_OUTPUT_PER_MTOK=0
# App-level retries on Anthropic 529 Overloaded (exponential backoff: 5s base,
# doubles each attempt, capped at 60s). Keep ≤3 so worst-case wait stays under
# nginx proxy_read_timeout (180s). Set to 0 to disable.
ANTHROPIC_529_MAX_RETRIES=3
# Prompt cost guards (characters).
INPUT_MAX_CHARS=100000
PRIOR_OUTPUT_MAX_CHARS=20000

# Secrets vault master key (QAX-3A): 32 bytes as 64 hex chars or base64, used to
# AES-256-GCM encrypt project QA secrets at rest. Generate with: openssl rand -hex 32
# Optional (app boots without it; setting/using a secret then returns 503).
SECRETS_KEY=

# Execution worker (QAX-3B): shared bearer token + lease duration (ms).
# Generate the token with: openssl rand -hex 32. Optional (worker API 503 until set).
WORKER_TOKEN=
WORKER_LEASE_MS=120000
